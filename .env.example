# ── GoFluent credentials ──
GOFLUENT_USERNAME=ton.email@esaip.org
GOFLUENT_PASSWORD=ton_mot_de_passe_microsoft
GOFLUENT_DOMAIN=esaip

# ── AI Provider: OpenRouter (primary) ──
# https://openrouter.ai — paid, reliable
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Autres modeles: anthropic/claude-3.5-sonnet, openai/gpt-4o, meta-llama/llama-3.3-70b

# ── AI Provider: Groq (fallback + Whisper) ──
# https://console.groq.com — gratuit, rapide, rate-limited
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# Aussi utilise pour Whisper (transcription audio)
WHISPER_MODEL=whisper-large-v3
# Autres: whisper-large-v3-turbo (plus rapide, un peu moins precis)

# ── AI Provider: OpenAI (fallback) ──
# https://platform.openai.com — paid
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Google AI (optionnel, pas utilise actuellement) ──
# GOOGLE_AI_API_KEY=AIza...

# ── Ordre de fallback ──
# 1. OpenRouter (si OPENROUTER_API_KEY present)
# 2. Groq (si GROQ_API_KEY present)
# 3. OpenAI (si OPENAI_API_KEY present)
# Le premier qui repond est utilise. Si il echoue, le suivant prend le relais.
