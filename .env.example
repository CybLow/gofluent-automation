# ── GoFluent credentials (required) ──
GOFLUENT_USERNAME=ton.email@esaip.org
GOFLUENT_PASSWORD=ton_mot_de_passe_microsoft
GOFLUENT_DOMAIN=esaip

# ── Optional profiles ──
# Append __PROFILE to every var (uppercased) and pass --profile PROFILE on the CLI.
# GOFLUENT_USERNAME__WORK=...
# GOFLUENT_PASSWORD__WORK=...
# GOFLUENT_DOMAIN__WORK=...

# ── Optional runtime overrides (defaults shown) ──
# GOFLUENT_DATA_DIR: dossier session.json + cache.txt
# GOFLUENT_LOGS_DIR: dossier des run.log timestampes
# GOFLUENT_MONTHLY_TARGET: valeur par defaut de --auto-run
# GOFLUENT_LANGUAGE: valeur par defaut de --language
GOFLUENT_DATA_DIR=./data
GOFLUENT_LOGS_DIR=./logs
GOFLUENT_MONTHLY_TARGET=13
GOFLUENT_LANGUAGE=Anglais
